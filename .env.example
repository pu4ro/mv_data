# ============================================================
# .env.example - 환경 변수 설정 예시
# 이 파일을 복사하여 .env로 저장 후 값을 수정하세요.
# cp .env.example .env
# ============================================================

# Kubernetes 네임스페이스
NAMESPACE=your-namespace

# Deployment 설정
DEPLOYMENT_NAME=busybox-cache-mounter
APP_LABEL=busybox-cache
IMAGE=cr.makina.rocks/external-hub/busybox:v0.1
REPLICAS=1

# 노드 선택 (kubectl get nodes 로 확인)
# 예: k3d-test-server-0, node1.example.com
NODE_HOSTNAME=your-node-hostname

# PVC 설정
PVC_NAME=vllm-cache
STORAGE_SIZE=80Gi
# ACCESS_MODE 옵션: ReadWriteOnce | ReadWriteMany | ReadOnlyMany
ACCESS_MODE=ReadWriteOnce
# 스토리지 클래스 (기본값 사용 시 주석 처리)
# STORAGE_CLASS=nfs-client

# 데이터 경로 (Pod 내부 마운트 경로)
TARGET_DIR=/data
MOUNT_PATH=/data
